# Copy to .env and fill in values. Never commit .env.
# In production, set these via your deployment (e.g. secret manager → env vars).

# ---- Auth (required in production; dev has insecure default) ----
AUTH_JWT_SECRET=

# ---- Optional overrides ----
# AUTH_COOKIE_NAME=auth_token
# AUTH_JWT_EXPIRES_IN=7d

# ---- db / postgresql-db ----
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=

# ---- Service URLs (Compose sets these for containers) ----
# JOBS_API_ENDPOINT=    # graphql-api → db-access
# GRAPHQL_API_ENDPOINT= # client-ui → graphql-api
# DB_ACCESS_ENDPOINT=   # client-ui → db-access (auth proxy)

# ---- Ports ----
# HTTP_PORT=  # per-service (4000, 4001, 4002)
# PORT=       # client-ui when using Cloud Run / platform default
